{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.json",
    "typeCheck": false,
    "builder": {
      "type": "swc",
      "options": {
        "filenames": ["src"],
        "ignore": ["**/node_modules/**", "**/dist/**", "**/*.spec.ts", "**/*.test.ts"],
        "stripLeadingPaths": true
      }
    }
  }
}
