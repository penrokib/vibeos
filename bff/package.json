{
  "name": "@vibeos/bff",
  "version": "0.1.0",
  "private": true,
  "description": "rokibrain BFF — NestJS 11 backend for app.rokibrain.com (Phase 2)",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
