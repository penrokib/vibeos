{
  "name": "@vibeos/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "rokibrain.app — single Electron desktop bundle (M01 shell + IPC contracts).",
  "license": "UNLICENSED",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run && jest",
    "test:daemon": "jest",
    "test:renderer": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "start": "electron-vite preview",
    "dist:mac": "yarn build && electron-builder --mac --config electron-builder.yml",
    "dist:linux": "yarn build && electron-builder --linux --config electron-builder.yml",
    "dist:win": "yarn build && electron-builder --win --config electron-builder.yml",
    "clean": "rm -rf out dist node_modules tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.3.9",
    "imapflow": "^1.0.193",
    "libsodium-wrappers": "^0.8.4",
    "nodemailer": "^6.10.1",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^3.25.20"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/libsodium-wrappers": "^0.8.2",
    "@types/node": "^22",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.1.5",
    "electron": "^32.2.7",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "happy-dom": "^20.9.0",
    "jest": "^30.3.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
